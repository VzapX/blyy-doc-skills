## 基线快照（doc-sync 防线 3 比对基准）

> 此章节由 `blyy-init-docs` 在 Phase 3 自动写入，由 `blyy-doc-sync` 防线 3 在每次审计时更新。
> AI 工具可读，但**不应手动编辑此章节** — 必须由确定性扫描命令的实际输出覆盖。

```yaml
snapshot_date: {{DATE}}
snapshot_commit: <!-- Phase 3 自动填充：当前 HEAD 短 SHA -->
last_synced_commit: <!-- Phase 3 自动填充：同 snapshot_commit，doc-sync 后续会更新此字段 -->
skill_version: blyy-init-docs v{{SKILL_VERSION}}

inventory:
  modules: <!-- Phase 3 -->
  entities: <!-- Phase 3：业务术语候选（实体/服务类）— 供 glossary 字段语义表完整性比对 -->
  features: <!-- Phase 3：用户可见功能数 — 供 modules.md 功能列表比对 -->
  config_items: <!-- Phase 3 -->

markers:
  todo_total: <!-- Phase 3 -->
  todo_by_priority:
    p0: <!-- Phase 3 -->
    p1: <!-- Phase 3 -->
    p2: <!-- Phase 3 -->
    p3: <!-- Phase 3 -->
  todo_by_type:
    business-context: <!-- Phase 3 -->
    design-rationale: <!-- Phase 3 -->
    ops-info: <!-- Phase 3 -->
    security-info: <!-- Phase 3 -->
    external-link: <!-- Phase 3 -->
    metric-baseline: <!-- Phase 3 -->
  unverified_total: <!-- Phase 3 -->

layer_distribution:
  layer1_core: <!-- Phase 3：4（README/AGENTS/ARCHITECTURE/modules） -->
  layer2_modules: <!-- Phase 3：模块数 -->
  layer3_aggregate: <!-- Phase 3：6（core-flow/config/glossary/DECISIONS/doc-maintenance/CHANGELOG） -->

fact_levels:
  t1_count: <!-- Phase 3 -->
  t2_count: <!-- Phase 3 -->
  t3_count: <!-- Phase 3 -->
```

